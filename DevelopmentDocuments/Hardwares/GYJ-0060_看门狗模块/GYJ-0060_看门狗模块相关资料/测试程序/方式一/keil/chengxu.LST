  19                                      延时函数
  20          *********************************************************************/
  21          void delay()//延时程序
  22          {
  23   1      uchar m,n,s;
  24   1      for(m=2;m>0;m--)
  25   1      for(n=20;n>0;n--)
  26   1      for(s=248;s>0;s--);
  27   1      }
  28          /********************************************************************
  29                                      主函数
  30          *********************************************************************/
  31          void main()
  32          {
  33   1              while(1)   //无限循环
  34   1              {
  35   2              P0=0X00;           //点亮P1.0口灯
  36   2               delay();  //延时
