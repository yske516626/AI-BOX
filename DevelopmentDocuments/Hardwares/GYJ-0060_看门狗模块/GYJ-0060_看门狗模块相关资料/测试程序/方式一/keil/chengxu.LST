  12          sbit LED=P1^0;   //定义单片机P1口的第0位 （即P1.0）
  13          sbit P20=P2^0;
  14          sbit P21=P2^1;
  15          sbit P22=P2^2;
  16          sbit P23=P2^3;
  17          sbit P24=P2^4;
